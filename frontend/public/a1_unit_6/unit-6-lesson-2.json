{
  "lesson_id": "a1_unit6_lesson02",
  "unit": 6,
  "lesson_number": 2,
  "level": "A1",
  "title": "Shopping clothes & returns",
  "description": "Learn to talk about sizes, fits, and how to return or exchange items.",
  "estimated_minutes": 30,
  "xp_reward": 150,
  "tasks": [
    {
      "task_id": "t0602_01",
      "type": "learn_card",
      "prompt": "Clothing store vocabulary",
      "content": {
        "grammar_focus": "Shopping vocabulary",
        "example_sentences": [
          "Do you have this in a bigger size?",
          "I'd like to return this.",
          "Can I exchange this for a different color?"
        ],
        "context": "At a clothing store."
      }
    },
    {
      "task_id": "t0602_02",
      "type": "listen_repeat",
      "prompt": "Say it clearly",
      "audio_key": "a1_u6_l2_repeat_01",
      "content": {
        "target_phrases": [
          "I want to return this shirt.",
          "Do you have the receipt?",
          "It doesn't fit well."
        ]
      }
    },
    {
      "task_id": "t0602_03",
      "type": "mcq",
      "prompt": "What is the customer asking?",
      "question": "If you want to give a shirt back and get your money, you ask for a:",
      "options": ["refund", "receipt", "size", "color"],
      "correct_option_index": 0
    },
    {
      "task_id": "t0602_04",
      "type": "fill_blank",
      "prompt": "Fill the size/fit questions",
      "content": {
        "sentence": "Do you have this in a smaller ___?",
        "options": ["size", "color", "style", "brand"],
        "correct": "size"
      }
    },
    {
      "task_id": "t0602_05",
      "type": "sort_words",
      "prompt": "Build the return request",
      "scramble": ["like", "to", "return", "this", "I'd"],
      "answer": "I'd like to return this"
    },
    {
      "task_id": "t0602_06",
      "type": "match_pairs",
      "prompt": "Match shopping phrases",
      "pairs": [
        {"left": "It's too big.", "right": "Do you have a smaller size?"},
        {"left": "I don't like the color.", "right": "Can I exchange it?"},
        {"left": "I'd like a refund.", "right": "Do you have the receipt?"}
      ]
    },
    {
      "task_id": "t0602_07",
      "type": "error_correction",
      "prompt": "Fix incorrect return phrases",
      "instruction": "Correct the sentence.",
      "wrong_sentence": "I want returning this.",
      "correct_sentence": "I want to return this."
    },
    {
      "task_id": "t0602_08",
      "type": "scenario_mcq",
      "prompt": "Choose the best response",
      "question": "Staff says: 'Do you have the receipt?' You reply:",
      "options": [
        "Yes, here it is.",
        "No, it is too big.",
        "I like blue.",
        "Thank you."
      ],
      "correct_option_index": 0
    },
    {
      "task_id": "t0602_09",
      "type": "speaking",
      "prompt": "Speak: try-on feedback",
      "content": {
        "min_words": 15,
        "example_response": "This shirt is too small. Do you have a medium size? I'd like to exchange it."
      }
    },
    {
      "task_id": "t0602_10",
      "type": "dialogue",
      "prompt": "Roleplay: exchange for a different color",
      "dialogue": {
        "setting": "A clothing store",
        "turns": [
          {"speaker": "Customer", "text": "I'd like to exchange this dress."},
          {"speaker": "Staff", "text": "Is there something wrong with it?"},
          {"speaker": "Customer", "text": "No, but I want it in blue, not red."}
        ]
      },
      "comprehension_questions": [
        {"question": "Why does the customer want to exchange the dress?", "expected_answer": "Because they want a different color."}
      ]
    },
    {
      "task_id": "t0602_11",
      "type": "lesson_summary",
      "prompt": "Lesson summary: Shopping, clothes & returns",
      "content": {
        "checklist": [
          "I can ask for a different size or color.",
          "I can return or exchange an item.",
          "I can answer questions about receipts."
        ]
      }
    }
  ]
}
