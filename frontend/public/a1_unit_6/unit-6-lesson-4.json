          "You should drink more water.",
          "I usually sleep eight hours.",
          "I feel stressed today."
        ]
      }
    },
    {
      "task_id": "t0604_03",
      "type": "mcq",
      "prompt": "Often/sometimes/never",
      "question": "If you do something zero times, you ___ do it.",
      "options": ["never", "often", "usually", "sometimes"],
      "correct_option_index": 0
    },
    {
      "task_id": "t0604_04",
      "type": "fill_blank",
      "prompt": "Present simple for routines",
      "content": {
        "sentence": "She ___ yoga every morning.",
        "options": ["do", "does", "doing", "done"],
        "correct": "does"
      }
    },
    {
      "task_id": "t0604_05",
      "type": "sort_words",
      "prompt": "Build the advice sentence",
      "scramble": ["should", "rest", "get", "You", "some"],
      "answer": "You should get some rest"
    },
    {
      "task_id": "t0604_06",
      "type": "match_pairs",
      "prompt": "Symptoms to questions",
      "pairs": [
        {"left": "I have a headache.", "right": "You should take a painkiller."},
        {"left": "I am very tired.", "right": "You should sleep early."},
        {"left": "I am thirsty.", "right": "You should drink some water."}
      ]
    },
    {
      "task_id": "t0604_07",
      "type": "error_correction",
      "prompt": "Fix should sentences",
      "instruction": "Correct the sentence.",
      "wrong_sentence": "You should to rest.",
      "correct_sentence": "You should rest."
    },
    {
      "task_id": "t0604_08",
      "type": "scenario_mcq",
      "prompt": "Best advice choice",
      "question": "Your friend says: 'I feel stressed from work.' You say:",
      "options": [
        "You should take a break.",
        "You should work more.",
        "I like coffee.",
        "Where is your office?"
      ],
      "correct_option_index": 0
    },
